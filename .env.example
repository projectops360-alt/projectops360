# ──────────────────────────────────────────────────────────
# ProjectOps360° — Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# Local/Development/Preview MUST use staging ref: gcxcljfzleasrleyyyda
# Production MUST use production ref: ocopmlnkvidvmxgiwvxw
# Enforced by scripts/validate-supabase-environment.mjs
# ──────────────────────────────────────────────────────────

# ── PUBLIC (safe for browser) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# ── PRIVATE (server-side only — never expose to browser) ──
DATABASE_URL=your_database_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Budget & Cost Management Engine — server-side rollout flags (default OFF).
# Use explicit staging project IDs. The literal "all" is rejected in production.
FINANCIAL_FOUNDATION_ENABLED=false
FINANCIAL_WRITERS_ENABLED=false
FINANCIAL_PROJECTIONS_ENABLED=false
FINANCIAL_UI_ENABLED=false
FINANCIAL_ISABELLA_ENABLED=false
FINANCIAL_PILOT_PROJECT_IDS=all
PMO_PROCESS_INTELLIGENCE_DASHBOARD_ENABLED=false
PMO_PORTFOLIO_ROLLUP_ENGINE_V1_ENABLED=false

# AI Provider (server-side only)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Drawing Intelligence — Autodesk Platform Services connector (server-side only)
# Create an app at https://aps.autodesk.com/myapps (Data Management + Model Derivative APIs)
# APS_CLIENT_ID=
# APS_CLIENT_SECRET=

# Drawing Intelligence — webhook endpoint shared secret (/api/webhooks/drawings)
# Generate a random 32+ char token; external systems send it as x-webhook-secret
# DRAWING_WEBHOOK_SECRET=

# Canonical public site URL (used for auth email redirect links in prod)
NEXT_PUBLIC_SITE_URL=https://projectops360.com

# Product Brain Control Center — STRICT server-side access allowlist (TASK 10A).
# Comma-separated emails. If unset, safe built-in defaults are used (see
# src/lib/product-brain/access.server.ts). Set the real PMO address here.
# PRODUCT_BRAIN_ALLOWED_EMAILS=efrain.pradas@gmail.com,pmo@your-domain.io

# ── Isabella Voice (OpenAI Realtime interface layer) ──────────────────────────
# Feature flag. Default OFF: when unset/not "true" the voice endpoints return
# 404 and no live-voice UI is offered — Isabella's panel is unchanged. Voice is
# an INTERFACE on top of Isabella; all data flows through her existing engines.
# Requires OPENAI_API_KEY. Rollback = unset this flag (no migration).
# ISABELLA_VOICE_ENABLED=false
# Optional overrides (defaults: gpt-realtime / marin — warm female voice)
# ISABELLA_VOICE_MODEL=gpt-realtime
# ISABELLA_VOICE_NAME=marin

# ── GitHub Intelligence Layer (software projects only) ────────────────────────
# Master feature flag. Default OFF: when unset/not "true" the module is fully
# dark (no nav, no dashboard/API, no webhook processing, no Isabella context).
# Rollback = unset this flag. Requires ALSO project_type='software_development'.
# GITHUB_INTELLIGENCE_ENABLED=false
#
# Platform GitHub App (Mode A install flow). All server-side only — NEVER expose.
# Create a GitHub App with READ-ONLY permissions (contents, metadata,
# pull_requests, actions, deployments, checks) and events: push, pull_request,
# pull_request_review, workflow_run, deployment, release, create, delete.
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=your-app-slug
# GITHUB_APP_PRIVATE_KEY=            # PEM; escape newlines as \n in one line
# GITHUB_APP_WEBHOOK_SECRET=         # random 32+ char token; verifies webhooks
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_BASE_URL=https://projectops360.vercel.app   # for manifest/callback URLs
#
# Optional: AES-256-GCM key (32-byte hex/base64 or passphrase) used to encrypt
# manifest-created GitHub App credentials at rest (Mode B). If unset, the app
# refuses to persist manifest secrets rather than storing plaintext.
# GITHUB_INTELLIGENCE_ENCRYPTION_KEY=
# Mining-ready task/milestone capture pilot (comma-separated project IDs; default OFF)
PROCESS_MINING_EVENT_CAPTURE_PROJECT_IDS=all
