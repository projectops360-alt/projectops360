# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# use npm as the canonical package manager (Vercel detects from package-lock.json)
pnpm-lock.yaml
pnpm-workspace.yaml
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase
.supabase

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea
# local-only
.claude/
dev_out.log
olla.bat

# sample plan PDFs — local testing only, may be copyrighted; do not commit
docs/sample-plans/*.pdf

.vercel

# Playwright E2E artifacts (Phase 4B multi-tab realtime test)
/test-results/
/playwright-report/
/playwright/.cache/
