# ============================================================================
# P2-T2 functional verification — LOCAL Supabase only (risk-capture-verification)
# ============================================================================
# Copy this file to `.env.test` (gitignored) and fill the values from
# `supabase status` (run inside a started `supabase start` stack). The verification
# test REFUSES to run unless NEXT_PUBLIC_SUPABASE_URL points at localhost.
#
#   cp .env.test.example .env.test
#   # ... fill SUPABASE_SERVICE_ROLE_KEY from `supabase status` ...
#   set -a && source .env.test && set +a
#   RISK_CAPTURE_VERIFY=1 npx vitest run src/lib/events/__tests__/risk-capture-verification.test.ts
#
# NEVER point these at production. NEVER commit `.env.test`.
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key-from-supabase-status